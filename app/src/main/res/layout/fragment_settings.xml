<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_settings"
            android:textColor="@color/color_text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="20dp"
            android:layout_marginTop="52dp"
            android:layout_marginBottom="20dp" />

        <!-- Appearance section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_appearance"
            android:textColor="@color/color_accent_cyan"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#00000000"
            app:cardElevation="0dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <include layout="@layout/item_setting_row"
                    android:id="@+id/setting_cursor_color"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/color_divider"
                    android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                <include layout="@layout/item_setting_row"
                    android:id="@+id/setting_cursor_scale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Performance section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_performance"
            android:textColor="@color/color_accent_cyan"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#00000000"
            app:cardElevation="0dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <include layout="@layout/item_setting_toggle"
                    android:id="@+id/setting_show_fps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/color_divider"
                    android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                <include layout="@layout/item_setting_toggle"
                    android:id="@+id/setting_wine_debug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Advanced section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_advanced"
            android:textColor="@color/color_accent_cyan"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#00000000"
            app:cardElevation="0dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <include layout="@layout/item_setting_row"
                    android:id="@+id/setting_box64_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/color_divider"
                    android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                <include layout="@layout/item_setting_toggle"
                    android:id="@+id/setting_save_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- About section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_about"
            android:textColor="@color/color_accent_cyan"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="#00000000"
            app:cardElevation="0dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_app_logo"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/color_text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_accent_cyan"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <Button
                        android:id="@+id/btn_github"
                        style="@style/WinlatorButton.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="GitHub"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_donate"
                        style="@style/WinlatorButton.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/settings_donate"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
