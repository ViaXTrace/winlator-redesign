<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- Hero Banner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="@dimen/banner_height"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="60dp"
            app:cardBackgroundColor="#00000000"
            app:cardElevation="0dp"
            app:cardCornerRadius="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glass_card_elevated">

                <!-- Background gradient accent -->
                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="end|top"
                    android:background="#0C00E5FF"
                    android:layout_marginTop="-40dp"
                    android:layout_marginEnd="-40dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="24dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_greeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_welcome"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="13sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tv_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="@color/color_text_primary"
                            android:textSize="30sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.02"
                            android:layout_marginTop="4dp" />

                        <View
                            android:layout_width="40dp"
                            android:layout_height="2dp"
                            android:background="@drawable/bg_glass_button_primary"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_status_dot" />

                            <TextView
                                android:id="@+id/tv_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/dashboard_ready"
                                android:textColor="@color/color_accent_green"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_app_logo"
                        android:contentDescription="@string/app_name"
                        android:alpha="0.8" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp">

            <!-- Containers stat -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_card_height"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#00000000"
                app:cardElevation="0dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_containers_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/color_accent_cyan"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-light" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_containers"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Shortcuts stat -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_card_height"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:cardBackgroundColor="#00000000"
                app:cardElevation="0dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_shortcuts_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/color_accent_purple"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-light" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_shortcuts"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Active stat -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="@dimen/stat_card_height"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="#00000000"
                app:cardElevation="0dp"
                app:cardCornerRadius="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_active_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/color_accent_green"
                        android:textSize="32sp"
                        android:fontFamily="sans-serif-light" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_active"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Quick Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_quick_actions"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <Button
                android:id="@+id/btn_new_container"
                style="@style/WinlatorButton.Primary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/dashboard_new_container"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="6dp" />

            <Button
                android:id="@+id/btn_add_shortcut"
                style="@style/WinlatorButton.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/dashboard_add_shortcut"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_shortcuts"
                android:drawablePadding="6dp" />

        </LinearLayout>

        <!-- System Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_system_info"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#00000000"
            app:cardElevation="0dp"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="20dp">

                <include layout="@layout/item_system_info_row"
                    android:id="@+id/row_wine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_divider"
                    android:layout_marginVertical="8dp" />

                <include layout="@layout/item_system_info_row"
                    android:id="@+id/row_box64"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_divider"
                    android:layout_marginVertical="8dp" />

                <include layout="@layout/item_system_info_row"
                    android:id="@+id/row_gpu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_divider"
                    android:layout_marginVertical="8dp" />

                <include layout="@layout/item_system_info_row"
                    android:id="@+id/row_rootfs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
