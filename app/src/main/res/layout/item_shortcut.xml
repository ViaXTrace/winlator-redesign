<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#00000000"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:padding="14dp"
        android:gravity="center">

        <!-- App Icon placeholder -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_glass_card_elevated">

            <ImageView
                android:id="@+id/iv_shortcut_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_shortcuts"
                android:layout_gravity="center"
                android:tint="@color/color_accent_cyan"
                android:contentDescription="@null" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_shortcut_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Name"
            android:textColor="@color/color_text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/tv_shortcut_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Container"
            android:textColor="@color/color_text_tertiary"
            android:textSize="10sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="3dp" />

        <Button
            android:id="@+id/btn_launch_shortcut"
            style="@style/WinlatorButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:text="@string/shortcut_launch"
            android:textSize="11sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
