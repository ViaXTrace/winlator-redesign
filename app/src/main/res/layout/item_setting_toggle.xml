<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:minHeight="56dp">

    <ImageView
        android:id="@+id/iv_toggle_icon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_settings"
        android:tint="@color/color_accent_cyan"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <TextView
            android:id="@+id/tv_toggle_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toggle title"
            android:textColor="@color/color_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_toggle_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumbTint="@color/color_accent_cyan"
        android:trackTint="@color/color_glass_border" />
</LinearLayout>
